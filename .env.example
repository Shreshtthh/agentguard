# ═══════════════════════════════════════════════════════════
# AgentGuard — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# === Stellar Testnet ===
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# === Agent Wallets (generated by: npm run setup) ===
AGENT_ALPHA_SECRET=
AGENT_ALPHA_PUBLIC=
AGENT_BETA_SECRET=
AGENT_BETA_PUBLIC=
AGENT_GAMMA_SECRET=
AGENT_GAMMA_PUBLIC=

# === AgentGuard Owner (deploys contract, receives x402 payments) ===
GUARD_SECRET=
GUARD_PUBLIC=

# === Known Recipient (whitelisted — used by normal-agent.js) ===
KNOWN_RECIPIENT_PUBLIC=

# === Unknown Recipient (attacker — used by rogue-agent.js) ===
UNKNOWN_RECIPIENT_PUBLIC=

# === Soroban Contract (set after deploying spending-policy) ===
SOROBAN_CONTRACT_ID=

# === AI (Groq — free at https://console.groq.com) ===
GROQ_API_KEY=

# === x402 Facilitator ===
X402_FACILITATOR_URL=https://www.x402.org/facilitator

# === API Server ===
PORT=4000
